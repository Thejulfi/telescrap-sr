{
  "name": "Rust Dev Container",
  "image": "rust:latest",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb",
        "ms-vscode.live-server",
        "pkief.material-icon-theme"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "rust-analyzer.check.command": "clippy"
      }
    }
  },
  "postCreateCommand": "rustup component add clippy rustfmt && rustc --version && cargo --version && cargo clippy --version"
}